library(tidyverse)
library(lubridate)
growth <- read_csv("Curtogrowth_data.csv") %>%
mutate(Date = mdy(Date),
N = E6_gate_dilution_drymass_corrected)
ts <- growth %>%
group_by(Date) %>%
summarize(N = mean(N, na.rm = TRUE)) %>%
arrange(Date) %>%
mutate(days = as.numeric(Date - min(Date)))
model <- lm(log(N) ~ days, data = ts)
r <- coef(model)[2]
generations_per_day <- r / log(2)
generations_per_day
growth <- read_csv("Curtogrowth_data.csv") %>%
mutate(
Date = mdy(Date),
N = E6_gate_dilution_drymass_corrected
) %>%
filter(!is.na(N), N > 0)
rates <- growth %>%
group_by(Treatment, bagid) %>%
arrange(Date) %>%
mutate(days = as.numeric(Date - first(Date))) %>%
filter(days > 0) %>%
do({
m <- lm(log(N) ~ days, data = .)
tibble(r = coef(m)[2])
}) %>%
mutate(
generations_per_day = r / log(2),
doubling_time_hours = (log(2)/r) * 24
)
rates %>%
group_by(Treatment) %>%
summarize(
mean_generations = mean(generations_per_day, na.rm = TRUE),
sd_generations = sd(generations_per_day, na.rm = TRUE),
mean_doubling_hours = mean(doubling_time_hours, na.rm = TRUE)
)
View(growth)
growth_summary <- growth %>%
group_by(Treatment, Date) %>%
summarize(
mean_cells = mean(N, na.rm = TRUE),
sd_cells = sd(N, na.rm = TRUE),
.groups = "drop"
)
ggplot(growth_summary, aes(Date, mean_cells, color = Treatment)) +
geom_ribbon(
aes(ymin = mean_cells - sd_cells,
ymax = mean_cells + sd_cells,
fill = Treatment),
alpha = 0.2,
color = NA
) +
geom_line(linewidth = 1) +
scale_y_log10() +
labs(
x = "Time",
y = "Cells per gram litter (log scale)",
color = "Strain",
fill = "Strain"
) +
theme_bw() +
theme(
legend.position = "top",
panel.grid = element_blank()
)
## and to get this across average temp
env <- readxl::read_excel("Environmental_data.xlsx") %>%
mutate(
datetime = parse_date_time(Reading, orders = c("dmy HMS", "dmy HM")),
Temperature = as.numeric(Temperature)
) %>%
filter(!is.na(datetime), !is.na(Temperature))
View(env)
lab_gr <- tibble(
Temperature = c(22, 28, 35),
gen_per_day = c(5.45, 8.4, 7.57)   # replace with values from joanna
)
env_pred <- env %>%
mutate(
pred_log_gen_per_day = approx(
x = lab_gr$Temperature,
y = log(lab_gr$gen_per_day),
xout = Temperature,
rule = 2   # clamp outside range
)$y,
pred_gen_per_day = exp(pred_log_gen_per_day),
pred_gen_time_hours = 24 / pred_gen_per_day
)
ggplot(env_pred, aes(datetime, pred_gen_time_hours)) +
geom_line(linewidth = 0.7) +
theme_bw() +
theme(panel.grid = element_blank()) +
labs(
x = "Time",
y = "Predicted generation time (hours)"
)
ggplot(env_pred, aes(datetime, pred_gen_per_day)) +
geom_line(linewidth = 0.7) +
theme_bw() +
theme(panel.grid = element_blank()) +
labs(
x = "Time",
y = "Predicted generations per day"
)
env_pred <- env_pred %>%
arrange(datetime) %>%
mutate(
dt_days = c(NA, diff(datetime) / ddays(1)),
expected_generations = pred_gen_per_day * dt_days
)
env_pred %>%
summarize(total_expected_generations = sum(expected_generations, na.rm = TRUE))
env_daily <- env_pred %>%
mutate(Date = as.Date(datetime)) %>%
group_by(Date) %>%
summarize(
mean_temp = mean(Temperature, na.rm = TRUE),
mean_pred_gen_per_day = mean(pred_gen_per_day, na.rm = TRUE),
mean_pred_gen_time_hours = mean(pred_gen_time_hours, na.rm = TRUE),
.groups = "drop"
)
env_daily
