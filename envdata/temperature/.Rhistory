library(lubridate)
base_dir <- "/Volumes/OfficeSMU/Research/research-projects/terrestrial/curtobacterium/curtoWarm/joanna-warm/field-data/temperature"
# 1) Find all csv files in 2021 + 2022 (recursively)
files <- list.files(
path = file.path(base_dir, c("2021", "2022")),
pattern = "\\.csv$",
recursive = TRUE,
full.names = TRUE
)
# Keep only CG/WG samples based on filename suffix like "_CG1.csv" or "_WG8.csv"
files <- files[str_detect(basename(files), "_(CG|WG)\\d+\\.csv$")]
# 2) File reader that is defensive about iButton column weirdness
read_ibutton <- function(fp) {
x <- readr::read_csv(fp, show_col_types = FALSE)
# iButton exports often have datetime in col 1, and temp/humidity as last 2 cols
# We'll standardize by position rather than fragile header names.
stopifnot(ncol(x) >= 3)
# Parse sample from filename: "2021-Apr-14_CG1.csv" -> "CG1"
sample <- str_match(basename(fp), "_((CG|WG)\\d+)\\.csv$")[,2]
treatment <- str_sub(sample, 1, 2)
plot <- as.integer(str_sub(sample, 3))
out <- tibble(
datetime_raw = x[[1]],
temperature  = suppressWarnings(as.numeric(x[[ncol(x) - 1]])),
humidity     = suppressWarnings(as.numeric(x[[ncol(x)]])),
treatment    = treatment,
plot         = plot,
file         = basename(fp)
) %>%
mutate(
# Try a couple common timestamp formats: "19/01/2021 01:21:01" etc
datetime = parse_date_time(
datetime_raw,
orders = c("dmy HMS", "dmy HM", "mdy HMS", "mdy HM", "Ymd HMS", "Ymd HM"),
