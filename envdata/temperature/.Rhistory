# 3) Load everything
dat <- map_dfr(files, read_ibutton) %>%
filter(!is.na(datetime))
# Optional: align to hour to avoid tiny timestamp offsets inflating SD
dat <- dat %>% mutate(datetime = floor_date(datetime, unit = "hour"))
# summarize mean ± SD across plots by treatment at each timestamp
summ <- dat %>%
group_by(treatment, plot) %>%
summarize(
temp_mean = mean(temperature, na.rm = TRUE),
temp_sd   = sd(temperature, na.rm = TRUE),
temp_max   = max(temperature, na.rm = TRUE),
temp_min   = min(temperature, na.rm = TRUE),
hum_mean  = mean(humidity, na.rm = TRUE),
hum_sd    = sd(humidity, na.rm = TRUE),
.groups = "drop"
) %>%
mutate(treatment = recode(treatment, CG = "Control", WG = "Warming"))
View(summ)
rm(list = ls())
setwd("/Volumes/OfficeSMU/Research/research-projects/terrestrial/curtobacterium/curtoWarm/joanna-warm/field-data/temperature")
library(tidyverse)
library(lubridate)
base_dir <- "/Volumes/OfficeSMU/Research/research-projects/terrestrial/curtobacterium/curtoWarm/joanna-warm/field-data/temperature"
# 1) Find all csv files in 2021 + 2022 (recursively)
files <- list.files(
path = file.path(base_dir, c("2021", "2022")),
pattern = "\\.csv$",
recursive = TRUE,
full.names = TRUE
)
# Keep only CG/WG samples based on filename suffix like "_CG1.csv" or "_WG8.csv"
files <- files[str_detect(basename(files), "_(CG|WG)\\d+\\.csv$")]
# 2) File reader that is defensive about iButton column weirdness
read_ibutton <- function(fp) {
x <- readr::read_csv(fp, show_col_types = FALSE)
# iButton exports often have datetime in col 1, and temp/humidity as last 2 cols
# We'll standardize by position rather than fragile header names.
stopifnot(ncol(x) >= 3)
# Parse sample from filename: "2021-Apr-14_CG1.csv" -> "CG1"
sample <- str_match(basename(fp), "_((CG|WG)\\d+)\\.csv$")[,2]
treatment <- str_sub(sample, 1, 2)
plot <- as.integer(str_sub(sample, 3))
out <- tibble(
datetime_raw = x[[1]],
temperature  = suppressWarnings(as.numeric(x[[ncol(x) - 1]])),
humidity     = suppressWarnings(as.numeric(x[[ncol(x)]])),
treatment    = treatment,
plot         = plot,
file         = basename(fp)
) %>%
mutate(
# Try a couple common timestamp formats: "19/01/2021 01:21:01" etc
datetime = parse_date_time(
datetime_raw,
orders = c("dmy HMS", "dmy HM", "mdy HMS", "mdy HM", "Ymd HMS", "Ymd HM"),
tz = "UTC"
)
) %>%
select(datetime, temperature, humidity, treatment, plot, file)
out
}
# 3) Load everything
dat <- map_dfr(files, read_ibutton) %>%
filter(!is.na(datetime))
# Optional: align to hour to avoid tiny timestamp offsets inflating SD
dat <- dat %>% mutate(datetime = floor_date(datetime, unit = "hour"))
# summarize mean ± SD across plots by treatment at each timestamp
summ <- dat %>%
group_by(treatment, plot) %>%
summarize(
temp_mean = mean(temperature, na.rm = TRUE),
temp_sd   = sd(temperature, na.rm = TRUE),
temp_max   = max(temperature, na.rm = TRUE),
temp_min   = min(temperature, na.rm = TRUE),
hum_mean  = mean(humidity, na.rm = TRUE),
hum_sd    = sd(humidity, na.rm = TRUE),
.groups = "drop"
) %>%
mutate(treatment = recode(treatment, CG = "Control", WG = "Warming"))
### add in min/max + sampling times
plot_means <- dat %>%
group_by(datetime, treatment, plot) %>%
summarize(
temp = mean(temperature, na.rm = TRUE),
hum  = mean(humidity, na.rm = TRUE),
.groups = "drop"
)
summ_ts <- plot_means %>%
group_by(datetime, treatment) %>%
summarize(
temp_mean = mean(temp, na.rm = TRUE),
temp_sd   = sd(temp, na.rm = TRUE),
temp_min  = min(temp, na.rm = TRUE),
temp_max  = max(temp, na.rm = TRUE),
hum_mean  = mean(hum, na.rm = TRUE),
hum_sd    = sd(hum, na.rm = TRUE),
hum_min   = min(hum, na.rm = TRUE),
hum_max   = max(hum, na.rm = TRUE),
.groups = "drop"
)
library(zoo)
k <- 24  # window size in points
summ_smooth <- summ_ts %>%
group_by(treatment) %>%
arrange(datetime) %>%
mutate(
across(
c(temp_mean, temp_sd, temp_min, temp_max,
hum_mean,  hum_sd,  hum_min,  hum_max),
~ rollmean(.x, k = k, fill = NA, align = "center")
)
) %>%
ungroup()
plot_df <- summ_smooth %>%
transmute(
datetime, treatment,
temp_mean, temp_sd, temp_min, temp_max,
hum_mean,  hum_sd,  hum_min,  hum_max
) %>%
pivot_longer(
cols = -c(datetime, treatment),
names_to = c("var", "stat"),
names_pattern = "(temp|hum)_(mean|sd|min|max)",
values_to = "value"
) %>%
pivot_wider(names_from = stat, values_from = value) %>%
mutate(panel = recode(var,
temp = "Temperature (°C)",
hum  = "Humidity (%)"))
start_date <- min(plot_df$datetime, na.rm = TRUE)
sampling_dates <- tibble(
datetime = start_date %m+% months(c(6, 12, 18)),
label = c("6 mo", "12 mo", "18 mo")
)
# IMPORTANT: set these names to match unique(plot_df$treatment)
cols <- c("CG" = "#4DA3C7", "WG" = "#F4A261")
fieldcond <- ggplot(plot_df, aes(x = datetime)) +
geom_ribbon(
aes(ymin = mean - sd, ymax = mean + sd, fill = treatment),
alpha = 0.18, linewidth = 0
) +
geom_line(aes(y = mean, color = treatment), linewidth = 0.8) +
geom_line(aes(y = min, color = treatment), linewidth = 0.5, linetype = "dotted") +
geom_line(aes(y = max, color = treatment), linewidth = 0.5, linetype = "dotted") +
facet_wrap(~ panel, ncol = 1, scales = "free_y") +
scale_fill_manual(values = cols) +
scale_color_manual(values = cols) +
labs(x = "Time", y = NULL, color = NULL, fill = NULL) +
geom_vline(
data = sampling_dates,
aes(xintercept = datetime),
linetype = "dashed",
linewidth = 0.5,
color = "grey30"
) +
theme_bw() +
theme(
legend.position = "top",
strip.background = element_blank()
)
fieldcond
ggsave("field-measurements.pdf", plot = fieldcond, width = 8, height = 4)
## average diff between treatments
diff_ts <- summ_smooth %>%
select(datetime, treatment,
temp_mean, hum_mean) %>%
pivot_wider(
names_from = treatment,
values_from = c(temp_mean, hum_mean)
) %>%
mutate(
delta_temp = temp_mean_WG - temp_mean_CG,
delta_hum  = hum_mean_WG  - hum_mean_CG
)
avg_diff <- diff_ts %>%
summarize(
mean_delta_temp = mean(delta_temp, na.rm = TRUE),
sd_delta_temp   = sd(delta_temp, na.rm = TRUE),
mean_delta_hum  = mean(delta_hum,  na.rm = TRUE),
sd_delta_hum    = sd(delta_hum,  na.rm = TRUE)
)
avg_diff
max_diff <- diff_ts %>%
filter(!is.na(delta_temp)) %>%
summarize(
max_delta_temp = max(delta_temp, na.rm = TRUE),
datetime_max_delta_temp = datetime[which.max(delta_temp)],
max_delta_hum = max(delta_hum, na.rm = TRUE),
datetime_max_delta_hum = datetime[which.max(delta_hum)]
)
max_diff
max_diff <- diff_ts %>%
filter(!is.na(delta_temp)) %>%
summarize(
max_delta_temp = max(delta_temp, na.rm = TRUE),
datetime_max_delta_temp = datetime[which.max(delta_temp)],
min_delta_temp = min(delta_temp, na.rm = TRUE),
datetime_min_delta_temp = datetime[which.min(delta_temp)],
max_delta_hum = max(delta_hum, na.rm = TRUE),
datetime_max_delta_hum = datetime[which.max(delta_hum)]
)
max_diff
avg_diff <- diff_ts %>%
summarize(
mean_delta_temp = mean(delta_temp, na.rm = TRUE),
sd_delta_temp   = sd(delta_temp, na.rm = TRUE),
mean_delta_hum  = mean(delta_hum,  na.rm = TRUE),
sd_delta_hum    = sd(delta_hum,  na.rm = TRUE)
)
avg_diff
rm(list = ls())
